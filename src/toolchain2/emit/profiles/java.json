{
  "schema_version": 1,
  "language": "java",
  "types": {
    "int8": "long",
    "uint8": "long",
    "int16": "long",
    "uint16": "long",
    "int32": "long",
    "uint32": "long",
    "int64": "long",
    "uint64": "long",
    "float32": "double",
    "float64": "double",
    "bool": "boolean",
    "str": "String",
    "None": "void",
    "Any": "Object",
    "Path": "pathlib.Path"
  },
  "generic_types": {
    "list": "ArrayList<{T}>",
    "dict": "HashMap<{K}, {V}>",
    "set": "HashSet<{T}>",
    "tuple": "ArrayList<Object>",
    "optional": "{T}"
  },
  "operators": {
    "bin": {
      "FloorDiv": "__floordiv",
      "Pow": "__pow"
    },
    "bool": {
      "And": "&&",
      "Or": "||"
    },
    "unary": {
      "Not": "!"
    },
    "precedence": {
      "Mult": 5, "Div": 5, "Mod": 5, "LShift": 5, "RShift": 5, "BitAnd": 5,
      "Add": 4, "Sub": 4, "BitOr": 4, "BitXor": 4,
      "Eq": 3, "NotEq": 3, "Lt": 3, "LtE": 3, "Gt": 3, "GtE": 3,
      "And": 2,
      "Or": 1,
      "USub": 6, "UAdd": 6, "Not": 6, "Invert": 6,
      "In": 3, "NotIn": 3, "Is": 3, "IsNot": 3
    }
  },
  "syntax": {
    "if": "if ({cond}) {",
    "elif": "} else if ({cond}) {",
    "else": "} else {",
    "while": "while ({cond}) {",
    "block_close": "}",
    "return": "return",
    "break": "break",
    "continue": "continue",
    "comment_prefix": "//"
  },
  "lowering": {
    "tuple_unpack_style": "individual_temps",
    "container_covariance": false,
    "closure_style": "closure_syntax",
    "with_style": "try_with_resources",
    "property_style": "method_call",
    "swap_style": "temp_var",
    "none_literal": "null",
    "bool_literals": ["true", "false"],
    "self_keyword": "this",
    "type_position": "prefix",
    "condition_parens": true,
    "block_braces": "braces",
    "stmt_terminator": ";",
    "string_type_owned": true,
    "exception_style": "native_throw"
  }
}
