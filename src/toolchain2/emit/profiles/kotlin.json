{
  "schema_version": 1,
  "language": "kotlin",
  "types": {
    "int64": "Long",
    "float64": "Double",
    "bool": "Boolean",
    "str": "String",
    "None": "Unit",
    "Any": "Any?",
    "Path": "java.nio.file.Path"
  },
  "generic_types": {
    "list": "MutableList<{T}>",
    "dict": "MutableMap<{K}, {V}>",
    "set": "MutableSet<{T}>",
    "tuple": "List<Any?>",
    "optional": "{T}?"
  },
  "operators": {
    "bin": {
      "FloorDiv": "__floordiv",
      "Pow": "__pow"
    },
    "bool": {
      "And": "&&",
      "Or": "||"
    },
    "unary": {
      "Not": "!"
    }
  },
  "syntax": {
    "if": "if ({cond}) {",
    "elif": "} else if ({cond}) {",
    "else": "} else {",
    "while": "while ({cond}) {",
    "block_close": "}",
    "return": "return",
    "break": "break",
    "continue": "continue",
    "comment_prefix": "//"
  },
  "lowering": {
    "tuple_unpack_style": "individual_temps",
    "container_covariance": false,
    "closure_style": "closure_syntax",
    "with_style": "try_finally",
    "property_style": "method_call",
    "swap_style": "temp_var",
    "none_literal": "null",
    "bool_literals": ["true", "false"],
    "self_keyword": "this",
    "type_position": "postfix_colon",
    "condition_parens": true,
    "block_braces": "braces",
    "stmt_terminator": "",
    "string_type_owned": true,
    "exception_style": "native_throw"
  }
}
