{
  "schema_version": 1,
  "language": "julia",

  "types": {
    "int8": "Int8",
    "uint8": "UInt8",
    "int16": "Int16",
    "uint16": "UInt16",
    "int32": "Int32",
    "uint32": "UInt32",
    "int64": "Int64",
    "uint64": "UInt64",
    "float32": "Float32",
    "float64": "Float64",
    "bool": "Bool",
    "str": "String",
    "None": "Nothing",
    "Any": "Any",
    "Path": "String"
  },

  "generic_types": {
    "list": "Vector{{T}}",
    "dict": "Dict{{K}, {V}}",
    "set": "Set{{T}}",
    "tuple": "Tuple{{...}}",
    "optional": "Union{{Nothing}, {T}}"
  },

  "operators": {
    "bin": {
      "Add": "+",
      "Sub": "-",
      "Mult": "*",
      "Div": "/",
      "FloorDiv": "fld",
      "Mod": "%",
      "Pow": "^",
      "BitAnd": "&",
      "BitOr": "|",
      "BitXor": "xor",
      "LShift": "<<",
      "RShift": ">>"
    },
    "bool": {
      "And": "&&",
      "Or": "||"
    },
    "cmp": {
      "Eq": "==",
      "NotEq": "!=",
      "Lt": "<",
      "LtE": "<=",
      "Gt": ">",
      "GtE": ">="
    },
    "unary": {
      "Not": "!",
      "USub": "-",
      "Invert": "~"
    }
  },

  "syntax": {
    "if": "if {cond}",
    "elif": "elseif {cond}",
    "else": "else",
    "while": "while {cond}",
    "block_close": "end",
    "return": "return",
    "break": "break",
    "continue": "continue",
    "comment_prefix": "#",
    "raise": "throw"
  },

  "lowering": {
    "tuple_unpack_style": "multi_return",
    "container_covariance": false,
    "closure_style": "native_nested",
    "with_style": "try_finally",
    "property_style": "field_access",
    "swap_style": "multi_assign",
    "none_literal": "nothing",
    "bool_literals": ["true", "false"],
    "self_keyword": "self",
    "type_position": "postfix_double_colon",
    "condition_parens": false,
    "block_braces": "end_keyword",
    "stmt_terminator": "",
    "string_type_owned": true,
    "exception_style": "native_throw"
  }
}
